<?xml version="1.0" encoding="UTF-8"?>
<!--
  HU-13: Logs estructurados.
  - En consola: formato legible para desarrollo.
  - En archivo logs/quizarena.json: formato JSON, listo para ser ingerido por
    una herramienta de analisis (ELK, Azure Monitor, etc.).
-->
<configuration>

    <appender name="CONSOLA" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="JSON" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/quizarena.json</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/quizarena-%d{yyyy-MM-dd}.json</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"servicio":"servicio-juego"}</customFields>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLA"/>
        <appender-ref ref="JSON"/>
    </root>

</configuration>
